# Valores por defecto para ejecucion LOCAL (python run_server.py / python main_app.py).

# Mongo local.
URL_BBDD=mongodb://localhost:27017/

# API local.
URL_API=https://127.0.0.1:5001

# Usado por scripts locales que inicializan datos.
URL_API_INIT=https://127.0.0.1:5001

# Base publica opcional para URLs de imagen. Vacio = usa host de la request.
PUBLIC_API_BASE_URL=

# CORS: '*' o lista separada por comas
CORS_ORIGINS=http://localhost,http://127.0.0.1,https://localhost,https://127.0.0.1

# Subidas
MAX_IMAGE_SIZE_MB=10

# JWT
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=120

# Seguridad de endpoints (JSON)
PUBLIC_ENDPOINTS=["/health","/iniciar_sesion","/registro","/logos"]
AUTH_REQUIRED_ENDPOINTS=["/add_rol","/eliminar_rol","/buscar_usuarios","/eliminar_usuario","/cambiar_nombre_usuario","/cambiar_password","/seleccionar_usuario","/verificar_rol","/predict_image","/validar_imagen","/opciones_plantas","/opciones_enfermedades","/opciones_formatos","/opciones_fuentes","/opciones_modelos","/opciones_filtros_docs","/subida_masiva","/listar_fuentes_importadas","/subida_masiva_zip","/editar_clases","/reemplazar_clases","/add_class","/crear_experimento","/obtener_experimentos","/solicitar_entrenamiento","/obtener_solicitudes_entrenamiento","/entrenar_modelo","/obtener_modelos","/cambiar_url_bbdd","/obtener_resultados_experimento","/imagen_resultado","/imagen_comparacion","/comparar_experimentos","/obtener_graficos_comparacion","/recuperar_campos","/etiquetas","/add_etiqueta","/modificar_etiqueta","/add_campo","/eliminar_campo","/add_dato","/eliminar_dato","/docs","/clasificar","/servir_n_archivos","/servir_n_archivos_sin_validar","/subir_imagen","/eliminar_imagen"]
AUTH_REQUIRED_PREFIXES=["/recuperar_etiquetas/","/devolver_campos_etiqueta/","/imagen_base64/"]
ROLE_REQUIRED_ENDPOINTS={"/add_rol":["admin"],"/eliminar_rol":["admin"],"/buscar_usuarios":["admin"],"/eliminar_usuario":["admin"],"/subida_masiva":["admin"],"/subida_masiva_zip":["admin"],"/editar_clases":["admin"],"/reemplazar_clases":["admin"],"/add_class":["admin"],"/crear_experimento":["admin"],"/obtener_solicitudes_entrenamiento":["admin"],"/entrenar_modelo":["admin"],"/cambiar_url_bbdd":["admin"],"/add_etiqueta":["admin"],"/modificar_etiqueta":["admin"],"/add_campo":["admin"],"/eliminar_campo":["admin"],"/add_dato":["admin","etiquetador"],"/eliminar_dato":["admin","etiquetador"],"/validar_imagen":["admin","etiquetador"],"/servir_n_archivos_sin_validar":["admin","etiquetador"],"/clasificar":["admin","etiquetador"]}
