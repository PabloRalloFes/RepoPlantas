# Copia este archivo a .env para ajustar valores en local o en la maquina de la UPV.

# Conexion interna de la API al contenedor Mongo.
URL_BBDD=mongodb://mongo:27017/

# URL que usan scripts internos para hablar con la API dentro de Docker.
URL_API=http://api:5001

# URL usada por el servicio initdb (perfil init).
URL_API_INIT=http://api:5001

# Base pública para URLs guardadas en BBDD (imagen_rgb y campos tipo imagen).
# Ejemplos:
# - Local: http://127.0.0.1:5001
# - Red local: http://192.168.1.50:5001
PUBLIC_API_BASE_URL=http://127.0.0.1:5001
